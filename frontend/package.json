{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.dev.ts --open",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint src/ --fix",
    "lint:eslint": "eslint src/ --fix --cache",
    "format": "oxfmt src/",
    "prepare": "cd .. && git config core.hooksPath frontend/.husky"
  },
  "dependencies": {
    "ejs": "5.0.1",
    "handlebars": "4.7.9",
    "lucide-vue-next": "1.0.0",
    "monaco-editor": "0.55.1",
    "pinia": "3.0.4",
    "pug": "3.0.4",
    "vue": "3.5.32",
    "vue-router": "5.0.4",
    "vuetify": "4.0.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "24.0.4",
    "@types/ejs": "3.1.5",
    "@types/node": "24.12.0",
    "@types/pug": "2.0.10",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/eslint-config-typescript": "14.7.0",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.58.0",
    "eslint-plugin-vue": "10.8.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-plugin-vue-devtools": "8.1.1",
    "vite-plugin-vuetify": "2.1.3",
    "vue-tsc": "3.2.6"
  },
  "engines": {
    "node": "20.19.0 || >=22.12.0"
  }
}
